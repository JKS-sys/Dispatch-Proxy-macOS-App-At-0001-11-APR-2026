{
  "name": "dispatch-proxy-macos-app",
  "productName": "Dispatch Proxy macOS App",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"npm run start:react\" \"npm run start:electron\"",
    "build:react": "cd frontend && npm run build",
    "start:react": "cd frontend && npm start",
    "start:electron": "electron electron/main.js",
    "pack": "NODE_ENV=production electron-builder --mac"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.0"
  },
  "build": {
    "productName": "Dispatch Proxy macOS App",
    "mac": {
      "category": "Utilities",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
